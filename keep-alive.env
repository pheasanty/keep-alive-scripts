# Configuración para el script de keep-alive
# Copia este archivo a .env y modifica los valores según necesites

# URL base de la API
API_BASE_URL=https://swallet-troe.onrender.com

# Intervalo de ping en segundos (25 minutos = 1500 segundos)
PING_INTERVAL=1500

# Timeout para las requests en segundos
TIMEOUT=30

# Número máximo de reintentos
MAX_RETRIES=3

# Directorio de logs
LOG_DIR=logs

# Nivel de logging (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Modo de ejecución (development, production, aggressive)
MODE=production
